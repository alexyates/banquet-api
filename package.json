{
  "author": "Alex Yates",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "zod": "^4.1.12"
  },
  "description": "Banquet",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  },
  "main": "index.js",
  "name": "banquet",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "tsc",
    "clean": "rm -R dev.sqlite3",
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/index.ts",
    "migrate": "npx knex migrate:latest --knexfile knexfile.ts",
    "seed": "npx knex seed:run --knexfile knexfile.ts",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test vitest"
  },
  "version": "1.0.0"
}